<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.2">
  <persistence-unit name="oceanPU" transaction-type="JTA">
    <!-- Create this JNDI JDBC resource inside Payara/GlassFish -->
    <jta-data-source>jdbc/oceanview</jta-data-source>

    <properties>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
